{
  "name": "shory-sme",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "web": "pnpm --filter @shory/web dev",
    "admin": "pnpm --filter @shory/admin dev",
    "api": "pnpm --filter @shory/api dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @shory/db db:studio",
    "setup:db": "bash scripts/apply-migration.sh"
  },
  "devDependencies": {
    "next-auth": "5.0.0-beta.30",
    "turbo": "^2"
  },
  "packageManager": "pnpm@9.14.1"
}
