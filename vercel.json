{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "apps/admin/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/admin(/?.*)",
      "dest": "apps/admin"
    },
    {
      "src": "/(.*)",
      "dest": "apps/web"
    }
  ]
}
